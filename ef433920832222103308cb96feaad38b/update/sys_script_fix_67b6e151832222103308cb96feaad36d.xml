        <script><![CDATA[(function() {
    var now = new GlideDateTime();
    var gr = new GlideRecord('u_appointment');
    gr.addQuery('u_appointment_date', '<', now); // appointments before now
    gr.addQuery('u_status', '!=', 'completed');
    gr.query();
	// gs.print(gr.u_status);

    while (gr.next()) {
        gr.u_status = 'cancelled';
        gr.update();
        gs.print('Cancelled: ' + gr.number);
    }
})();]]></script>
