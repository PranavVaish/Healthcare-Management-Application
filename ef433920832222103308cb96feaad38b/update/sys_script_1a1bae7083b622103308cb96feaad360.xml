        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {
    var roomsys = current.u_room_assigned;
    var grroom = new GlideRecord('u_room');
    // grroom.addQuery('u_number.', roomsys)
    if (grroom.get(roomsys)) {
        gs.addInfoMessage('i am inside');
        grroom.u_occupied_beds += 1;
        grroom.update();
        var wardid = grroom.u_ward_id;
        var grward = new GlideRecord('u_ward');
        // grward.addQuery('u_number', wardid)
        // grward.query()
        if (grward.get(wardid)) {
            // var a = grward.getValue('u_occupancy') + 1
            grward.u_occupancy += 1;
            // grward.setValue('u_occupancy', a)
            grward.update();
        }
    }
})(current, previous);]]></script>
